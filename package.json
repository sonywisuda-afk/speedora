{
  "name": "speedora",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "node ops/dev-server/dev.mjs",
    "dev:restart": "node ops/dev-server/dev.mjs --restart",
    "dev:supervise": "node ops/dev-server/dev.mjs --supervise",
    "dev:stop": "node ops/dev-server/stop.mjs",
    "dev:status": "node ops/dev-server/status.mjs",
    "doctor": "node ops/dev-server/doctor.mjs",
    "doctor:fix": "node ops/dev-server/doctor.mjs --fix",
    "setup:path": "node ops/dev-server/setup-path.mjs",
    "build": "pnpm --filter \"./packages/**\" build && pnpm --filter \"./apps/**\" build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  }
}
